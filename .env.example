# Server
PORT=3000
NODE_ENV=production
BASE_URL=https://bharat-resume.railway.app

# Twilio Sandbox
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=resumes

# Upstash Redis
REDIS_URL=

# LLM
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PRIMARY=gpt-4o-mini
LLM_FALLBACK=claude-sonnet-4-6

# Payment provider (razorpay | cashfree). Cashfree is the current default after
# Razorpay KYC rejection 2026-07-08. Rollback to razorpay is a single env flip.
PAYMENT_PROVIDER=cashfree

# Razorpay (kept for rollback — do not delete)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Cashfree Payments (Payment Gateway product).
# CASHFREE_ENV: sandbox (test-mode UPI real-path) or production (KYC-gated).
# Get keys from Cashfree dashboard → Developers → API Keys.
# Webhook secret comes from Developers → Webhooks → your endpoint config.
CASHFREE_ENV=sandbox
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_WEBHOOK_SECRET=

# Admin
ADMIN_USERNAME=meet
ADMIN_PASSWORD=

# Pilot mode: set true for the free JECRC run — students get the clean
# (un-watermarked) PDF + full edit budget without paying. Leave false/blank
# for the normal ₹49 paid flow.
PILOT_MODE=

# Secret pepper for phone-number hashing. REQUIRED in production: without it a
# leaked phone hash can be brute-forced back to the number. Generate a long
# random value, e.g.  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PHONE_HASH_SECRET=

# Optional: raises GitHub API rate limit from 60/hr (unauth) to 5000/hr.
# Used by src/enrichment/github.js when a student drops a repo URL in projects step.
GITHUB_TOKEN=

# Max concurrent PDF render+watermark pipelines per process (default 2). Each
# spins a Chromium page and rasterizes A4 at 3x, so this caps peak memory under
# a burst of inbound messages. Raise only if the container has more RAM.
RENDER_CONCURRENCY=
